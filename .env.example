# Default Sinas workspace URL
VITE_DEFAULT_WORKSPACE_URL=https://pulsr.sinas.cloud

# Optional default runtime application id sent as X-Application on agent discovery.
# Deployments can override this per workspace in local storage.
VITE_DEFAULT_APPLICATION_ID=sinas/ai

# File storage namespace/collection for chat attachments.
# Self-hosting companies can override these values for their own file service setup.
VITE_FILES_NAMESPACE=sinas-ai
VITE_FILES_COLLECTION=chat-uploads
